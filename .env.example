NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-workers
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Alerts / Resend
RESEND_API_KEY=re_your_resend_api_key
ALERT_WORKER_SECRET=replace-with-a-long-random-secret
# Local/dev: set this to a sender Resend allows for your account, for example
# onboarding@resend.dev if your Resend account supports it. Do not hardcode it in code.
# Production: use a verified Upvane domain sender after DNS verification, e.g.
# Upvane <alerts@upvane.com>
ALERTS_EMAIL_FROM="Upvane <alerts@upvane.com>"
